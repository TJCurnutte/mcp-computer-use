#!/usr/bin/env python3
"""MCP server for macOS computer use: screenshots, mouse, keyboard."""

import base64
import io
import json
import time
from pathlib import Path

import mss
import pyautogui
from mcp.server.fastmcp import FastMCP
from PIL import Image

mcp = FastMCP("mcp-computer-use")

# macOS Retina scaling: pyautogui works in screen coordinates, mss in physical pixels.
# We expose screenshots at a fixed max dimension to the model and scale clicks back up.
MAX_SCREENSHOT_DIM = 1280


def _get_scale_factor():
    """Return the primary display's scale factor (e.g. 2.0 for Retina)."""
    try:
        import Quartz
        # CGMainDisplayID returns the display id; then use CGDisplayScreenActualSize
        # For simplicity, we derive from the display size and pixel dimensions.
        main_id = Quartz.CGMainDisplayID()
        bounds = Quartz.CGDisplayBounds(main_id)
        pixel_width = Quartz.CGDisplayPixelsWide(main_id)
        scale = pixel_width / bounds.size.width
        return scale
    except Exception:
        return 1.0


def _list_displays():
    """Return list of display dicts: index, width, height, scale."""
    displays = []
    with mss.MSS() as sct:
        for i, monitor in enumerate(sct.monitors[1:], start=1):
            displays.append(
                {
                    "index": i,
                    "left": monitor["left"],
                    "top": monitor["top"],
                    "width": monitor["width"],
                    "height": monitor["height"],
                    "scale": _get_scale_factor(),
                }
            )
    return displays


def _capture(display: int = 0, region: tuple = None):
    """Capture a screenshot and return a (PIL Image, display_info) tuple."""
    with mss.MSS() as sct:
        if region:
            left, top, width, height = region
            monitor = {"left": left, "top": top, "width": width, "height": height}
        elif display == 0:
            monitor = sct.monitors[0]  # all screens
        else:
            monitor = sct.monitors[display]
        sct_img = sct.grab(monitor)
        img = Image.frombytes("RGB", sct_img.size, sct_img.bgra, "raw", "BGRX")
    return img, monitor


def _resize_for_model(img: Image.Image) -> Image.Image:
    """Resize image to fit within MAX_SCREENSHOT_DIM while keeping aspect ratio."""
    max_dim = max(img.width, img.height)
    if max_dim <= MAX_SCREENSHOT_DIM:
        return img
    scale = MAX_SCREENSHOT_DIM / max_dim
    new_size = (int(img.width * scale), int(img.height * scale))
    return img.resize(new_size, Image.Resampling.LANCZOS)


def _image_to_base64(img: Image.Image) -> str:
    buf = io.BytesIO()
    img.save(buf, format="PNG")
    return base64.b64encode(buf.getvalue()).decode("utf-8")


def _click_scale() -> float:
    """Return the ratio of original screen pixels to model screenshot pixels."""
    with mss.MSS() as sct:
        monitor = sct.monitors[0]
        max_dim = max(monitor["width"], monitor["height"])
    if max_dim <= MAX_SCREENSHOT_DIM:
        return 1.0
    return max_dim / MAX_SCREENSHOT_DIM


@mcp.tool()
def get_display_info() -> str:
    """Get information about all connected displays."""
    return json.dumps(_list_displays(), indent=2)


@mcp.tool()
def get_cursor_position() -> str:
    """Return the current mouse cursor position."""
    x, y = pyautogui.position()
    return json.dumps({"x": x, "y": y})


@mcp.tool()
def screenshot(display: int = 0, scale: bool = True) -> str:
    """Take a screenshot and return a base64-encoded PNG.

    Args:
        display: 0 for all screens, 1+ for a specific monitor.
        scale: whether to scale down to the model-sized coordinate space.
    """
    img, monitor = _capture(display)
    original_width, original_height = img.width, img.height
    if scale:
        img = _resize_for_model(img)
    b64 = _image_to_base64(img)
    meta = {
        "width": img.width,
        "height": img.height,
        "original_width": original_width,
        "original_height": original_height,
        "display": display,
        "scale_factor": _get_scale_factor(),
        "click_scale": _click_scale() if scale else 1.0,
        "image": f"data:image/png;base64,{b64}",
    }
    return json.dumps(meta)


@mcp.tool()
def mouse_move(x: int, y: int) -> str:
    """Move the cursor to the given (x, y) coordinate in model screenshot space."""
    scale = _click_scale()
    px, py = int(x * scale), int(y * scale)
    pyautogui.moveTo(px, py)
    return json.dumps({"x": px, "y": py})


@mcp.tool()
def mouse_click(
    x: int,
    y: int,
    button: str = "left",
    clicks: int = 1,
) -> str:
    """Click at the given (x, y) coordinate in model screenshot space."""
    scale = _click_scale()
    px, py = int(x * scale), int(y * scale)
    pyautogui.click(px, py, button=button, clicks=clicks)
    return json.dumps({"clicked": True, "x": px, "y": py, "button": button, "clicks": clicks})


@mcp.tool()
def mouse_scroll(x: int, y: int, scroll_x: int = 0, scroll_y: int = 0) -> str:
    """Scroll the mouse wheel at the given (x, y) coordinate."""
    scale = _click_scale()
    px, py = int(x * scale), int(y * scale)
    pyautogui.hscroll(scroll_x, px, py)
    pyautogui.scroll(scroll_y, px, py)
    return json.dumps({"scrolled": True, "x": px, "y": py, "scroll_x": scroll_x, "scroll_y": scroll_y})


@mcp.tool()
def keyboard_type(text: str) -> str:
    """Type the given text as if it were typed on the keyboard."""
    pyautogui.typewrite(text, interval=0.01)
    return json.dumps({"typed": text})


@mcp.tool()
def key(keys: str) -> str:
    """Press a key or key combination, e.g. 'cmd+c' or 'shift+tab'.

    Modifiers should be joined with '+'.
    """
    parts = [p.strip() for p in keys.split("+")]
    if len(parts) > 1:
        pyautogui.keyDown(*parts[:-1])
        pyautogui.keyDown(parts[-1])
        pyautogui.keyUp(parts[-1])
        pyautogui.keyUp(*parts[:-1])
    else:
        pyautogui.keyDown(parts[0])
        pyautogui.keyUp(parts[0])
    return json.dumps({"key": keys})


@mcp.tool()
def hold_key(key: str, duration: float = 1.0) -> str:
    """Hold a key down for a number of seconds."""
    pyautogui.keyDown(key)
    time.sleep(duration)
    pyautogui.keyUp(key)
    return json.dumps({"held": key, "duration": duration})


@mcp.tool()
def wait(duration: float = 1.0) -> str:
    """Wait for a number of seconds."""
    time.sleep(duration)
    return json.dumps({"waited": duration})


if __name__ == "__main__":
    mcp.run()
